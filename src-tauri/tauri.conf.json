{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mahee Motion",
  "version": "0.1.0",
  "identifier": "com.mahee.motion",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Mahee Motion",
        "width": 1440,
        "height": 920,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "Maheertha",
    "copyright": "Copyright (c) 2026 Maheertha",
    "shortDescription": "Mahee Motion video editor",
    "longDescription": "Mahee Motion is a Windows desktop video editor built for timeline editing, preview, and export.",
    "windows": {
      "webviewInstallMode": {
        "type": "offlineInstaller",
        "silent": true
      },
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
